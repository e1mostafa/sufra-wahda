# ============================================================
# سُفرة واحدة — Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================================

# ─── DATABASE ────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sufra_wahda_db
DB_USER=sufra_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Full connection string (auto-built from above in docker-compose)
DATABASE_URL=Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}

# ─── REDIS ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── JWT ─────────────────────────────────────────────────────
# Must be at least 32 characters long and random
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_KEY_MIN_32_CHARS!!
JWT_ISSUER=sufra-wahda
JWT_AUDIENCE=sufra-wahda-clients
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── CLOUDINARY (Image Storage) ──────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── VONAGE (SMS - OTP) ──────────────────────────────────────
# Get from: https://dashboard.nexmo.com
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_FROM_NAME=SufraWahda

# ─── SENDGRID (Email) ────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@sufra-wahda.com
SENDGRID_FROM_NAME=سُفرة واحدة

# ─── FIREBASE (Push Notifications) ──────────────────────────
# Get from: https://console.firebase.google.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# Firebase Web Config (for frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── FAWRY (Payment Gateway) ─────────────────────────────────
# Get from: https://developer.fawrystaging.com
FAWRY_MERCHANT_CODE=your_merchant_code
FAWRY_SECURITY_KEY=your_security_key
FAWRY_BASE_URL=https://atfawry.fawrystaging.com
# Production: https://atfawry.com

# ─── STRIPE (Card Payments) ──────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── GOOGLE MAPS ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_server_key
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_browser_key

# ─── API URLs (Frontend) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SIGNALR_URL=http://localhost:5000

# Production:
# NEXT_PUBLIC_API_URL=https://api.sufra-wahda.com/api/v1
# NEXT_PUBLIC_SIGNALR_URL=https://api.sufra-wahda.com

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─── ENVIRONMENT ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# Production values: Production | Staging

# ─── LOGGING ─────────────────────────────────────────────────
SERILOG_MIN_LEVEL=Information
# Options: Verbose | Debug | Information | Warning | Error | Fatal

# ─── RAILWAY DEPLOYMENT ──────────────────────────────────────
# These are set automatically by Railway
# RAILWAY_STATIC_URL=
# PORT=5000

# ─── DOMAIN SETTINGS ─────────────────────────────────────────
APP_DOMAIN=sufra-wahda.com
API_DOMAIN=api.sufra-wahda.com
CUSTOMER_DOMAIN=sufra-wahda.com
RESTAURANT_DOMAIN=restaurant.sufra-wahda.com
ADMIN_DOMAIN=admin.sufra-wahda.com
DRIVER_DOMAIN=driver.sufra-wahda.com

# ─── PLATFORM SETTINGS ───────────────────────────────────────
DEFAULT_COMMISSION_PERCENTAGE=15
DEFAULT_DELIVERY_FEE_EGP=10
MIN_DRIVER_EARNINGS_PER_DELIVERY=8
LOYALTY_POINTS_PER_EGP=1
LOYALTY_POINT_VALUE_EGP=0.10
MAX_DELIVERY_RADIUS_KM=15
DEFAULT_CITY=المنيا

# ─── HANGFIRE (Background Jobs) ──────────────────────────────
HANGFIRE_USERNAME=admin
HANGFIRE_PASSWORD=CHANGE_ME_HANGFIRE_PASSWORD

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_GENERAL_WINDOW_MINUTES=1
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MINUTES=15
RATE_LIMIT_OTP_MAX=3
RATE_LIMIT_OTP_WINDOW_MINUTES=10
